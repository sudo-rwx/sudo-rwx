# Example environment variables for sudo-rwx

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/sudo_rwx

# JWT secret for auth tokens
JWT_SECRET=your_jwt_secret_here

# SMTP settings for email notifications (use Ethereal or real provider)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
